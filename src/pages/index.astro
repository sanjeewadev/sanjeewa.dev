---
import Layout from '../layouts/Layout.astro';
import '../styles/home.css'; 

// Local asset imports
import heroImg0 from '../assets/hero/premium-website-design-for-creative-studios.webp';
import heroImg1 from '../assets/hero/high-performance-photography-portfolio-website.webp';
import heroImg2 from '../assets/hero/custom-event-booking-website-development.webp';

import imgElinaPix from '../assets/Project/elinapix-photography-portfolio-website.webp';
import imgDJ from '../assets/Project/dj-christerna-dj-booking-website.webp';

import imgProfile from '../assets/me/sanjeewa-vipula-kumara-freelance-web-developer.webp';

// THE BAIT (SEO Meta Data)
const pageTitle = "Custom Website Design for Small Businesses | Freelance Web Developer";
const pageDescription = "Need a fast, stunning website? I am a freelance web developer building high-converting, custom websites for small businesses. Get more clients today.";

// Advanced AEO & Local Search Schema (Including new FAQ Schema)
const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://sanjeewa.dev/#person",
      "name": "Sanjeewa Vipula Kumara",
      "jobTitle": "Freelance Web Developer",
      "url": "https://sanjeewa.dev",
      "alumniOf": {
         "@type": "CollegeOrUniversity",
         "name": "Cardiff Metropolitan University"
      }
    },
    {
      "@type": "ProfessionalService",
      "@id": "https://sanjeewa.dev/#service",
      "url": "https://sanjeewa.dev",
      "name": "Sanjeewa Dev",
      "description": "High-Converting Custom Website Design for Small Businesses",
      "priceRange": "$$"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does a custom small business website cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A high-performance custom website starts at $150 for a fast, static landing page. Full business and commerce websites with content management start at $299."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need SEO for my small business website?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Every website I build includes a strict Technical SEO foundation—meaning it is lightning-fast and mobile-optimized so Google can read it easily and rank you higher."
          }
        }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <main class="hybrid-site">
        
<!-- =========================================
             1. THE HOOK (High-Converting Hero)
             ========================================= -->
        <section class="hero-split-modern">
            <div class="container hero-split-grid">
                
                <!-- Left: Content & Copywriting -->
                <div class="hero-split-content scroll-fade-up">
                    <p class="hero-kicker">Freelance Web Developer</p>
                    <h1 class="hero-title-split">Get a fast, custom website that brings you more customers.</h1>
                    
                    <h2 class="hero-subtitle-split text-dark-muted">
                        High-converting designs for <br>
                        <span class="dynamic-word-wrapper">
                            <span class="dynamic-word text-brand">Small Businesses.</span><span class="type-cursor">|</span>
                        </span>
                    </h2>
                    
                    <p class="hero-description-split text-dark-muted">
                        Stop losing clients to slow, outdated templates. I build hassle-free, lightning-fast websites that look incredible, rank higher on Google, and turn your visitors into paying customers.
                    </p>
                    
                    <div class="hero-actions-split">
                        <a href="/contact" class="btn-brand">Get Your Website in 7 Days</a>
                        <a href="/#work" class="btn-text-link text-dark-main ml-24">See Real Results ↗</a>
                    </div>
                </div>

                <!-- Right: The Sliding Image Frame -->
                <div class="hero-split-visual scroll-fade-up delay-150">
                    <div class="visual-frame">
                        <img src={heroImg0.src} alt="Custom website design for creative studios" class="hero-slide active" loading="eager" />
                        <img src={heroImg1.src} alt="High-converting website design for small businesses" class="hero-slide" loading="lazy" />
                        <img src={heroImg2.src} alt="Automated event booking website layout" class="hero-slide" loading="lazy" />
                        <div class="visual-overlay"></div>
                    </div>
                </div>

            </div>
        </section>

        <!-- =========================================
             THE LIGHT CANVAS (Sales Funnel Content)
             ========================================= -->
        <div class="light-canvas">

            <!-- 2. THE PHILOSOPHY (Business Value Focus) -->
            <section class="container section-philosophy text-center">
                <p class="section-kicker text-dark-muted">THE STANDARD</p>
                <h2 class="scroll-fade-up philosophy-title">
                    Your business doesn't just need a digital brochure. It needs an engine for growth. By focusing on <strong class="text-brand">lightning-fast speeds</strong> and <strong class="text-brand">conversion-first design</strong>, I build digital assets that actually generate leads.
                </h2>
            </section>

            <!-- 3. CORE COMPETENCIES (Bento Box) -->
            <section id="services" class="container section-expertise">
                <div class="section-label-block">
                    <p class="section-kicker text-dark-muted">01 // MY SERVICES</p>
                    <h2 class="scroll-fade-up">High-Converting Websites for <br><span class="text-brand">Small Businesses</span></h2>
                </div>

                <div class="bento-grid">
                    
                    <div class="competency-card scroll-fade-up delay-0">
                        <div class="card-header">
                            <p class="card-num text-dark-muted">01</p>
                            <div class="card-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                            </div>
                        </div>
                        <h3>Ultra-Fast Landing Pages</h3>
                        <p class="card-description">High-speed, custom-coded landing pages designed to capture leads immediately. Built for perfect Google scores, zero lag, and a flawless mobile experience to stop visitors from leaving.</p>
                        <div class="tech-stack-row">
                            <span>Lightning Fast</span>
                            <span>Mobile Optimized</span>
                            <span>More Leads</span>
                        </div>
                    </div>

                    <div class="competency-card highlight-blue scroll-fade-up delay-150">
                        <div class="card-header">
                            <p class="card-num text-brand">02</p>
                            <div class="card-icon text-brand">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                            </div>
                        </div>
                        <h3>Done-For-You Business Sites</h3>
                        <p class="card-description">Fully tailored websites for service businesses. I handle the setup, SEO formatting, and secure contact forms so you can focus entirely on running your day-to-day business.</p>
                        <div class="tech-stack-row">
                            <span>Easy to Manage</span>
                            <span>Local SEO Setup</span>
                            <span>Secure Forms</span>
                        </div>
                    </div>

                    <div class="competency-card scroll-fade-up delay-300">
                        <div class="card-header">
                            <p class="card-num text-dark-muted">03</p>
                            <div class="card-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                            </div>
                        </div>
                        <h3>Premium Portfolio Designs</h3>
                        <p class="card-description">Bespoke digital portfolios for creative professionals like DJs and photographers. Focused on stunning visuals and highly reliable email routing so you never miss a booking.</p>
                        <div class="tech-stack-row">
                            <span>Increase Bookings</span>
                            <span>Reliable Email</span>
                            <span>Stunning Design</span>
                        </div>
                    </div>

                </div>
            </section>

        <!-- 4. CLIENT PROJECTS (Case Studies) -->
            <section id="work" class="container section-work">
                <div class="section-label-block">
                    <p class="section-kicker text-dark-muted">02 // PROVEN RESULTS</p>
                    <h2 class="scroll-fade-up">Client <span class="text-brand">Success Stories</span></h2>
                </div>

                <div class="work-grid">
                    
                    <a href="/elinapix-case-study" class="work-card-case scroll-fade-up delay-0">
                        <div class="work-visual">
                            <img src={imgElinaPix.src} alt="Custom event photography website design for French Riviera photographer" loading="lazy" />
                        </div>
                        <div class="work-meta">
                            <h3>ElinaPix (French Riviera)</h3>
                            <p class="work-subtitle">Event Photography Booking Platform</p>
                            <p class="work-description">Her previous website was failing to generate sales. I engineered a custom, lightning-fast WordPress platform with integrated local SEO and a secure payment gateway. Today, the business consistently ranks on Google and captures direct, automated client bookings.</p>
                            <div class="tech-stack-row work-tags">
                                <span>Custom WordPress</span>
                                <span>Local SEO</span>
                                <span>Payment Gateway</span>
                            </div>
                        </div>
                    </a>

                    <a href="/dj-christerna-case-study" class="work-card-case scroll-fade-up delay-150">
                        <div class="work-visual">
                            <img src={imgDJ.src} alt="Custom DJ website design for Dubai event professional" loading="lazy" />
                        </div>
                        <div class="work-meta">
                            <h3>DJ Christerna (Dubai)</h3>
                            <p class="work-subtitle">Custom Website & SEO Strategy</p>
                            <p class="work-description">The client was locked out of his previous website by a restrictive developer. I rebuilt his entire digital presence using custom WordPress, handing over 100% ownership of his domain, hosting, and code. I also implemented an aggressive SEO strategy to help him grow in the highly competitive Dubai market.</p>
                            <div class="tech-stack-row work-tags">
                                <span>100% Ownership</span>
                                <span>Custom WordPress</span>
                                <span>Dubai SEO</span>
                            </div>
                        </div>
                    </a>

                </div>

                <div class="view-all-wrapper scroll-fade-up delay-300">
                    <a href="/coming-soon" class="btn-brand">View All Case Studies</a>
                </div>
            </section>
            
            <!-- 5. INVESTMENT MODELS (Pricing) -->
            <section id="packages" class="container section-pricing">
                <div class="section-label-block centered mb-64">
                    <p class="section-kicker text-dark-muted">03 // UPFRONT PRICING</p>
                    <h2 class="scroll-fade-up">Transparent pricing.<br><span class="text-brand">No hidden fees.</span></h2>
                </div>

                <div class="pricing-grid">
                    
                    <div class="pricing-card scroll-fade-up delay-0">
                        <h3 class="package-name">Static Launch</h3>
                        <div class="price-block">
                            <span class="price-label">Starting at</span>
                            <div class="price-amount">$150</div>
                        </div>
                        
                        <p class="package-desc">
                            <strong>Perfect for simple portfolios.</strong><br><br>
                            Ultra-fast, highly secure sites built to turn visitors into leads. <em>Note: Does not include a dashboard to change your own content.</em>
                        </p>
                        
                        <hr class="card-divider">

                        <ul class="package-features">
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Maximum loading speed</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Flawless mobile layout</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Technical SEO Foundation</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Zero ongoing maintenance</li>
                        </ul>
                    </div>

                    <div class="pricing-card highlight-blue scroll-fade-up delay-150">
                        <div class="popular-badge">MOST POPULAR</div>
                        <h3 class="package-name">Business & Commerce</h3>
                        <div class="price-block">
                            <span class="price-label">Starting at</span>
                            <div class="price-amount text-brand">$299</div>
                        </div>
                        
                        <p class="package-desc">
                            <strong>The complete business engine.</strong><br><br>
                            Includes a simple dashboard to change your own content, full e-commerce capabilities, and local search engine optimization.
                        </p>

                        <hr class="card-divider">
                        
                        <ul class="package-features">
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Easy content management</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Full online store integration</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Advanced SEO Configuration</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Secure payment gateways</li>
                        </ul>
                    </div>

                    <div class="pricing-card scroll-fade-up delay-300">
                        <h3 class="package-name">Bespoke Enterprise</h3>
                        <div class="price-block">
                            <span class="price-label">Starting at</span>
                            <div class="price-amount">$499</div>
                        </div>
                        
                        <p class="package-desc">
                            <strong>For high-end, scaling brands.</strong><br><br>
                            Elite architecture offering unbreakable security, 100% custom UI design, and significantly faster speeds than standard platforms.
                        </p>

                        <hr class="card-divider">
                        
                        <ul class="package-features">
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Enterprise-grade security</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Unrestricted custom design</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Elite performance metrics</li>
                            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Custom admin dashboard</li>
                        </ul>
                    </div>

                </div>

                <!-- THE SEO UPSELL BLOCK -->
                <div class="seo-upsell-block scroll-fade-up delay-450">
                    <div class="seo-upsell-content">
                        <h3>Already have a website? Need more traffic?</h3>
                        <p>In addition to web design, I offer dedicated Monthly SEO Campaigns. Whether I built your site or someone else did, I can optimize your platform to bring you more clients.</p>
                        <a href="/contact" class="btn-text-link text-brand">Get a Free SEO Audit ↗</a>
                    </div>
                </div>

            </section>

            <!-- 6. CLIENT TRUST (Google Reviews Slider) -->
            <section class="container section-google-reviews">
                <div class="section-label-block">
                    <p class="section-kicker text-dark-muted">04 // CLIENT TRUST</p>
                    <h2 class="scroll-fade-up">Verified <span class="text-brand">Google Reviews</span></h2>
                </div>

                <div class="reviews-carousel-container scroll-fade-up delay-150">
                    
                    <button class="slider-arrow prev-arrow" aria-label="Previous Review">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
                    </button>

                    <div class="reviews-slider-wrapper">
                        <div class="reviews-track" id="reviewsTrack">
                            
                            <div class="google-review-card">
                                <div class="review-header">
                                    <div class="reviewer-info">
                                        <div class="reviewer-avatar">E</div>
                                        <div class="reviewer-details">
                                            <span class="reviewer-name">Elina Kabakova</span>
                                            <div class="review-stars">★★★★★</div>
                                        </div>
                                    </div>
                                    <div class="google-logo">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google Logo" width="24" height="24" />
                                    </div>
                                </div>
                                <p class="review-text">I’m happy with the work done by Sanjeewa. The website looks aesthetically beautiful and elegant, exactly as I envisioned. The entire project was handled with a high level of professionalism, and I truly appreciate the attention to detail. Highly recommended!</p>
                            </div>

                            <div class="google-review-card">
                                <div class="review-header">
                                    <div class="reviewer-info">
                                        <div class="reviewer-avatar brand-bg">C</div>
                                        <div class="reviewer-details">
                                            <span class="reviewer-name">chris terna</span>
                                            <div class="review-stars">★★★★★</div>
                                        </div>
                                    </div>
                                    <div class="google-logo">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google Logo" width="24" height="24" />
                                    </div>
                                </div>
                                <p class="review-text">Wow this is amazing knowing how this guy building website for me
He amazing he knows the work🙌🏿👍🏼</p>
                            </div>

                        </div>
                    </div>

                    <button class="slider-arrow next-arrow" aria-label="Next Review">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                    </button>
                    
                </div> 

                <div class="review-ctas scroll-fade-up delay-300">
                    <a href="#" class="btn-brand" target="_blank" rel="noopener">Leave a Review</a>
                    <a href="#" class="btn-text-link text-dark-main" target="_blank" rel="noopener">View all on Google ↗</a>
                </div>

            </section>

   <!-- 7. THE DEVELOPER (About Me with Image) -->
            <section id="about" class="container section-about">
                <div class="about-grid">
                    <div class="about-visual scroll-fade-up">
                        <img src={imgProfile.src} alt="Sanjeewa Vipula Kumara - Freelance Web Developer for Small Businesses" class="profile-img" loading="lazy" />
                    </div>
                    
                    <div class="about-content">
                        <div class="about-header">
                            <p class="section-kicker text-dark-muted">05 // YOUR DEVELOPER</p>
                            <h2 class="scroll-fade-up delay-150 about-title">The partner <br><span class="text-brand">behind your growth.</span></h2>
                        </div>
                        <div class="about-text scroll-fade-up delay-300">
                            <p>Hi, I’m Sanjeewa. I am an independent web developer based in Sri Lanka, dedicated to building high-converting websites for businesses across Australia, Europe, and worldwide.</p>
                            
                            <p>I understand that hiring an international developer can be stressful. My approach is built on clear communication, absolute reliability, and delivering exactly what I promise. While my technical foundation is backed by a Software Engineering degree from <strong class="text-dark-main">Cardiff Metropolitan University</strong>, my daily focus is entirely on solving your business problems. I handle the complex technology, so you can focus on running your business.</p>
                            
                            <p>I don't just write code; I build digital assets that help you grow. Whether we are launching a lightning-fast portfolio to showcase your work or a dynamic WordPress engine to capture local leads, my priority is getting you a return on your investment.</p>
                            
                            <p>When I step away from the keyboard, I focus on analog creativity—studying photography and the visual arts.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 8. FREQUENTLY ASKED QUESTIONS (AEO Optimized) -->
            <section id="faq" class="container section-faq">
                <div class="section-label-block centered mb-64">
                    <p class="section-kicker text-dark-muted">06 // PROJECT DETAILS</p>
                    <h2 class="scroll-fade-up">Common <span class="text-brand">Questions.</span></h2>
                </div>

                <div class="faq-container">
                    
                    <div class="faq-item scroll-fade-up delay-0">
                        <button class="faq-question">
                            <span>How much does a custom small business website cost?</span>
                            <div class="faq-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </div>
                        </button>
                        <div class="faq-answer">
                            <p>A high-performance custom website starts at $150 for a fast, static landing page. Full business and commerce websites with content management start at $299. I provide transparent pricing with absolutely no hidden fees.</p>
                        </div>
                    </div>

                    <div class="faq-item scroll-fade-up delay-100">
                        <button class="faq-question">
                            <span>Do I need SEO for my small business website?</span>
                            <div class="faq-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </div>
                        </button>
                        <div class="faq-answer">
                            <p>Yes. Every website I build includes a strict Technical SEO foundation—meaning it is lightning-fast and mobile-optimized so Google can read it easily and rank you higher. We can also discuss ongoing monthly SEO campaigns if you want to aggressively outrank your local competitors.</p>
                        </div>
                    </div>

                    <div class="faq-item scroll-fade-up delay-200">
                        <button class="faq-question">
                            <span>How long does it take to build a custom business website?</span>
                            <div class="faq-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </div>
                        </button>
                        <div class="faq-answer">
                            <p>Most standard business websites are launched within 7 to 14 days. Because I write clean custom code and do not rely on clunky page builders, I can move quickly while maintaining an elite standard of quality.</p>
                        </div>
                    </div>

                    <div class="faq-item scroll-fade-up delay-300">
                        <button class="faq-question">
                            <span>How does the process work if we are in different countries?</span>
                            <div class="faq-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </div>
                        </button>
                        <div class="faq-answer">
                            <p>I work seamlessly with clients in Australia, Europe, and worldwide on a daily basis. We rely on clear communication via email and scheduled milestone reviews to ensure your project is delivered flawlessly, no matter your time zone.</p>
                        </div>
                    </div>

                    <div class="faq-item scroll-fade-up delay-400">
                        <button class="faq-question">
                            <span>Do I own the website and the domain?</span>
                            <div class="faq-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </div>
                        </button>
                        <div class="faq-answer">
                            <p>Absolutely. I build transparent partnerships. Once the final invoice is paid, you have 100% ownership of your domain, hosting, and all project files. You are never locked into a contract.</p>
                        </div>
                    </div>

                </div>
            </section>

            <!-- 9. THE INITIATION (Final CTA) -->
            <section class="container section-final-cta scroll-fade-up">
                <div class="final-cta-content">
                    <h2 class="final-cta-title">Ready to get <span class="text-brand">more customers?</span></h2>
                    <p class="final-cta-text">Let's discuss your business goals and build a website that actually generates revenue.</p>
                    <a href="/contact" class="btn-brand">Get Your Free Consultation</a>
                </div>
            </section>

        </div> <!-- End Light Canvas -->

    </main>

    <script src="../script/hero.js"></script>
    <script src="../script/reviews.js"></script>
    <script src="../script/scroll.js"></script>
    <script src="../script/faq.js"></script>
</Layout>