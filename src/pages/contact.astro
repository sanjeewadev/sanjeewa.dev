---
import Layout from '../layouts/Layout.astro';
import '../styles/contact.css'; 

// THE BAIT (SEO Meta Data)
const pageTitle = "Hire a Freelance Web Developer | Get a Free Website Quote";
const pageDescription = "Ready to grow your business? Hire an expert freelance web developer for a high-converting, custom website. Request a free quote today. I reply within 24 hours.";

// Advanced Local & Global SEO Schema
const schemaData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Sanjeewa Vipula Kumara",
  "description": "Get a free quote for custom website design and development.",
  "url": "https://sanjeewa.dev/contact",
  "mainEntity": {
    "@type": "Person",
    "name": "Sanjeewa Vipula Kumara",
    "jobTitle": "Freelance Web Developer",
    "email": "hello.sanjeewa@outlook.com",
    "telephone": "+94776369256",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Colombo",
      "addressCountry": "LK"
    },
    "sameAs": [
      "https://linkedin.com/in/sanjeewadev",
      "https://github.com/sanjeewadev"
    ]
  }
};
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    
    <header class="contact-hero-minimal">
        <div class="container contact-hero-content-centered scroll-fade-up">
            <p class="hero-kicker">GET YOUR FREE QUOTE</p>
            <h1 class="contact-title-minimal text-dark-main">Start getting <br><span class="text-brand">more customers.</span></h1>
            <p class="contact-subtitle-minimal text-dark-muted">
                Whether you need a lightning-fast portfolio or a complete business engine, let's discuss your goals. Fill out the form below, and <strong>I will personally reply within 24 hours</strong> to discuss your project.
            </p>
        </div>
    </header>

    <main class="contact-canvas">
        <div class="container">
            <div class="contact-grid">
                
                <div class="contact-channels scroll-fade-up delay-0">
                    
                    <div class="channel-card">
                        <h3>Direct Email</h3>
                        <div class="copy-link-group">
                            <a href="mailto:hello.sanjeewa@outlook.com" class="channel-link">hello.sanjeewa@outlook.com ↗</a>
                            <button class="copy-btn" onclick="copyToClipboard('hello.sanjeewa@outlook.com', this)" aria-label="Copy Email">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-copy"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-check"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            </button>
                        </div>
                    </div>
                    
                    <div class="channel-card">
                        <h3>WhatsApp Direct</h3>
                        <div class="copy-link-group">
                            <a href="https://wa.me/94776369256" class="channel-link" target="_blank" rel="noopener">+94 77 636 9256 ↗</a>
                            <button class="copy-btn" onclick="copyToClipboard('+94776369256', this)" aria-label="Copy Phone Number">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-copy"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-check"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            </button>
                        </div>
                    </div>
                    
                    <div class="channel-card">
                        <h3>Social Network</h3>
                        <div class="modern-social-grid">
                            
                            <a href="https://linkedin.com/in/sanjeewadev" class="social-link-minimal" aria-label="LinkedIn" target="_blank" rel="noopener">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                                    <rect x="2" y="9" width="4" height="12"></rect>
                                    <circle cx="4" cy="4" r="2"></circle>
                                </svg>
                            </a>

                            <a href="https://github.com/sanjeewadev" class="social-link-minimal" aria-label="GitHub" target="_blank" rel="noopener">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                                </svg>
                            </a>

                        </div>
                    </div>
                    
                </div>

                <div class="contact-form-wrapper scroll-fade-up delay-0">
                    <form action="https://api.web3forms.com/submit" method="POST" class="solid-premium-form" id="contactForm" novalidate>
                        
                        <input type="hidden" name="access_key" value="065ef0f5-7ba0-4210-add9-4534771c8b49">
                        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
                        <input type="hidden" name="subject" value="New Lead from Sanjeewa.dev!">

                        <div class="solid-input-group">
                            <label for="name">Name / Brand</label>
                            <input type="text" id="name" name="name" required placeholder="e.g. Sanjeewa">
                            <span class="error-text">Please enter your name (at least 2 characters).</span>
                        </div>
                        
                        <div class="solid-input-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" required placeholder="hello@yourbusiness.com">
                            <span class="error-text">Please enter a valid email address.</span>
                        </div>
                        
                        <div class="solid-input-group">
                            <label for="country">Location (Country)</label>
                            <input type="text" id="country" name="country" required placeholder="e.g. Australia or Europe">
                            <span class="error-text">Please let me know where you are located.</span>
                        </div>
                        
                        <div class="solid-input-group">
                            <label for="message">Project Details</label>
                            <textarea id="message" name="message" rows="5" required placeholder="Tell me about your business goals, current website problems, or ask me anything..."></textarea>
                            <span class="error-text">Please provide a few more details (at least 10 characters).</span>
                        </div>
                        
                        <button type="submit" class="submit-btn btn-brand btn-full-width mt-32">Get Your Free Consultation</button>
                        
                        <p style="text-align: center; margin-top: 16px; font-size: 0.85rem; color: #666;">
                            🔒 Your information is secure. No commitment required.
                        </p>
                    </form>
                </div>

            </div>
        </div>
    </main>

    <script src="../script/nav.js"></script>
    <script src="../script/scroll.js"></script>
    
    <script is:inline>
        function copyToClipboard(text, button) {
            navigator.clipboard.writeText(text).then(() => {
                button.classList.add('copied');
                setTimeout(() => {
                    button.classList.remove('copied');
                }, 2000);
            });
        }
        // --- REAL-TIME FORM VALIDATION ---
        document.addEventListener("DOMContentLoaded", () => {
            const form = document.getElementById("contactForm");
            if (!form) return;

            const nameInput = document.getElementById("name");
            const emailInput = document.getElementById("email");
            const countryInput = document.getElementById("country");
            const messageInput = document.getElementById("message");

            // Validation Logic Functions
            const isValidName = () => nameInput.value.trim().length >= 2;
            const isValidEmail = () => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim());
            const isValidCountry = () => countryInput.value.trim().length >= 2;
            const isValidMessage = () => messageInput.value.trim().length >= 10;

            // UI Updater Function
            const updateUI = (input, isValid) => {
                if (isValid) {
                    input.classList.remove("is-invalid");
                    input.classList.add("is-valid");
                } else {
                    input.classList.remove("is-valid");
                    input.classList.add("is-invalid");
                }
            };

            // 1. Real-Time Feedback (Fires as the user types)
            nameInput.addEventListener("input", () => updateUI(nameInput, isValidName()));
            emailInput.addEventListener("input", () => updateUI(emailInput, isValidEmail()));
            countryInput.addEventListener("input", () => updateUI(countryInput, isValidCountry()));
            messageInput.addEventListener("input", () => updateUI(messageInput, isValidMessage()));

            // 2. Submission Lock (Prevents sending if errors exist)
            form.addEventListener("submit", (e) => {
                const nameValid = isValidName();
                const emailValid = isValidEmail();
                const countryValid = isValidCountry();
                const messageValid = isValidMessage();

                // Force UI update on all fields in case they clicked submit while empty
                updateUI(nameInput, nameValid);
                updateUI(emailInput, emailValid);
                updateUI(countryInput, countryValid);
                updateUI(messageInput, messageValid);

                // If ANY field is invalid, STOP the form from submitting
                if (!nameValid || !emailValid || !countryValid || !messageValid) {
                    e.preventDefault(); 
                }
            });
        });
    </script>
</Layout>