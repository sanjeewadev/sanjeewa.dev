---
import '../styles/nav.css';
---

<header class="main-nav" id="mainNav">
    <div class="container nav-container">
        
        <a href="/" class="nav-brand" aria-label="Sanjeewa.dev Homepage">
            Sanjeewa<span class="text-brand">.dev</span>
        </a>

        <nav class="nav-links desktop-links" aria-label="Main navigation">
            <a href="/#services">Services</a>
            <a href="/coming-soon">Case Studies</a>
            <a href="/#packages">Pricing</a>
        </nav>

        <div class="nav-cta desktop-cta">
            <a href="/contact" class="btn-brand-small">Get a Free Quote</a>
        </div>

        <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle Menu" aria-expanded="false">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="menu-icon">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>

    </div>

    <div class="mobile-menu" id="mobileMenu">
        <nav class="mobile-menu-inner" aria-label="Mobile navigation">
            <a href="/#services" class="mobile-link">Services</a>
            <a href="/coming-soon" class="mobile-link">Case Studies</a>
            <a href="/#packages" class="mobile-link">Pricing</a>
            <a href="/contact" class="btn-brand" style="margin-top: 24px; width: 100%;">Get a Free Quote</a>
        </nav>
    </div>
</header>

<script src="../script/nav.js"></script>