---
import "./projectDetails.css";

const plasticImages = [
  { src: "https://picsum.photos/200/300?1", alt: "Plastic Component 1" },
  { src: "https://picsum.photos/200/300?2", alt: "Plastic Component 2" },
  { src: "https://picsum.photos/200/300?3", alt: "Plastic Component 3" },
  { src: "https://picsum.photos/200/300?4", alt: "Plastic Component 4" },
  { src: "https://picsum.photos/200/300?5", alt: "Plastic Component 5" },
  { src: "https://picsum.photos/200/300?6", alt: "Plastic Component 6" },
];
---

{/* --- SECTION 1: PLASTICS --- */}
<section class="all-projects-section">
  <div class="container">
    <div class="all-projects-layout">
      {/* Text Side (Sticky) */}
      <div class="all-projects-info sticky">
        <h2 class="all-projects-title">
          Plastic <span class="text-red">Division</span>
        </h2>
        <p class="all-projects-desc">
          Our advanced injection moulding facility is the heart of component
          localization. Producing everything from automotive body parts to
          electrical enclosures with micron-level precision.
        </p>
        <p class="all-projects-desc">
          Our advanced injection moulding facility is the heart of component
          localization. Producing everything from automotive body parts to
          electrical enclosures with micron-level precision.
        </p>
      </div>

      {/* Gallery Side */}
      <div class="all-projects-gallery">
        {
          plasticImages.map((img) => (
            <div class="dyno-gallery-item">
              <img src={img.src} alt={img.alt} loading="lazy" />
              <div class="dyno-gallery-overlay">
                <span>View Image</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

{/* --- SECTION 2: SCOOTERS (Darker Theme) --- */}
<section class="all-projects-section dark-variant">
  <div class="container">
    <div class="all-projects-layout reversed">
      {/* Text Side */}
      <div class="all-projects-info sticky">
        <h2 class="all-projects-title">
          Assembly <span class="text-red">Line</span>
        </h2>
        <p class="all-projects-desc">
          The birthplace of the Dyno Scooter. A fully conveyorised assembly
          system where 14 local components meet global engineering standards.
          Every unit undergoes rigorous PDI testing before rolling out.
        </p>
        <p class="all-projects-desc">
          The birthplace of the Dyno Scooter. A fully conveyorised assembly
          system where 14 local components meet global engineering standards.
          Every unit undergoes rigorous PDI testing before rolling out.
        </p>
      </div>

      {/* Gallery Side */}
      <div class="all-projects-gallery">
        {
          plasticImages.map((img) => (
            <div class="dyno-gallery-item">
              <img src={img.src} alt={img.alt} loading="lazy" />
              <div class="dyno-gallery-overlay">
                <span>View Image</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
