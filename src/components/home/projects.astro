---
import '../../styles/home/home.css';
---


<section id="peojects" class="projects-section section-padding">
      <div class="section-title right-title">
        <div></div>
        <h1>My Projects</h1>
      </div>
      <div class="projects-cards">
        <!-- Projects 01 -->
        <div class="project-card grid-2 card">
          <div class="projects-card-img-side">
            <img
              src="/assets/Project/elina-website.png"
              alt="WordPress photography portfolio website for ElinaPix with gallery layout" />
          </div>
          <div class="projects-card-content-side">
            <h2>ElinaPix - Photography Portfolio (WordPress)</h2>
            <p>
              A clean, responsive portfolio for a photographer with gallery
              pages, easy image management, and on-page SEO. Simple inquiry flow
              and payment options make it practical for real bookings. Built to
              load fast and look great on mobile.
            </p>
            <a
              class="btn-black visit-site-btn"
              href="/projects/elinapix-photography-portfolio"
              >Visit Site
              <img
                src="/assets/Icons/external-link-icon-to-wordpress-website-development.png"
                alt="external site link icon"
            /></a>
          </div>
        </div>
        <!-- Projects 02 -->
        <div class="project-card grid-2 card">
          <div class="projects-card-content-side">
            <h2>Axivelt Solutions - Company Website</h2>
            <p>
              Multi-page brand site with Services, About, and Contact. Semantic
              HTML, responsive CSS, and lightweight JS for smooth interactions.
              Structured for SEO with clear calls-to-action and a simple lead
              form, ready to scale with a blog.
            </p>
            <a
              class="btn-black visit-site-btn"
              href="/projects/elinapix-photography-portfolio"
              >Visit Site
              <img
                src="/assets/Icons/external-link-icon-to-wordpress-website-development.png"
                alt="external site link icon"
            /></a>
          </div>
          <div class="projects-card-img-side">
            <img
              src="/assets/Project/elina-website.png"
              alt="Company website for Axivelt Solutions with services and contact sections" />
          </div>
        </div>
        <!-- Projects 03 -->
        <div class="project-card grid-2 card">
          <div class="projects-card-img-side">
            <img
              src="/assets/Hero/wordpress-website-design-develompnet-sanjeewa.dev-hero-section-image.jpg"
              alt="WooCommerce store demo product grid and checkout screens" />
          </div>
          <div class="projects-card-content-side">
            <h2>Island Tea Co. - WooCommerce Store (Demo)</h2>
            <p>
              End-to-end WooCommerce demo: product catalog, variations, coupons,
              shipping rules, secure checkout, order emails, and basic
              analytics. Built with a sandbox payment gateway and a clean admin
              for easy product updates.
            </p>
            <a
              class="btn-black visit-site-btn"
              href="/projects/elinapix-photography-portfolio"
              >Visit Site
              <img
                src="/assets/Icons/external-link-icon-to-wordpress-website-development.png"
                alt="external site link icon"
            /></a>
          </div>
        </div>
      </div>
    </section>