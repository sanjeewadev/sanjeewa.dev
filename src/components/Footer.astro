---
import '../styles/footer.css';
---

<footer class="site-footer">
    <div class="container footer-container">
        
        <div class="footer-main-grid">
            
            <div class="footer-brand-column">
                <a href="/" class="footer-logo" aria-label="Homepage">Sanjeewa<span class="text-brand">.dev</span></a>
                <p class="footer-tagline text-light-muted">High-converting custom website design for small businesses and creative professionals.</p>
            </div>

            <nav class="footer-column" aria-label="Footer Navigation">
                <h4 class="footer-heading">Navigation</h4>
                <a href="/" class="footer-link">Home</a>
                <a href="/#services" class="footer-link">Services</a>
                <a href="/coming-soon" class="footer-link">Case Studies</a>
                <a href="/#packages" class="footer-link">Pricing Plans</a>
            </nav>
            
            <nav class="footer-column" aria-label="Social Links">
                <h4 class="footer-heading">Connect</h4>
                <a href="/contact" class="footer-link">Get a Free Quote</a>
                <a href="https://linkedin.com/in/sanjeewadev" class="footer-link" target="_blank" rel="noopener">LinkedIn</a>
                <a href="https://github.com/sanjeewadev" class="footer-link" target="_blank" rel="noopener">GitHub</a>
            </nav>
            
            <nav class="footer-column" aria-label="Legal Links">
                <h4 class="footer-heading">Legal</h4>
                <a href="/coming-soon" class="footer-link">Privacy Policy</a>
                <a href="/coming-soon" class="footer-link">Terms of Service</a>
            </nav>
            
        </div>

        <div class="footer-bottom">
            <p class="copyright text-light-muted">&copy; {new Date().getFullYear()} Sanjeewa Vipula Kumara. All rights reserved.</p>
            
            <div class="footer-meta">
                <span class="location-text">Based in Sri Lanka • Serving Australia & Europe</span>
                
                <button class="back-to-top-btn" aria-label="Back to top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="19" x2="12" y2="5"></line>
                        <polyline points="5 12 12 5 19 12"></polyline>
                    </svg>
                </button>
            </div>
        </div>
        
    </div>
</footer>