---

// Import your images here (Update paths if needed)
import ElinaImg from "../../assets/Project/sanjeewa-web-developer-projects-portfolio-elinapix.com-photographer-portfolio.avif";
import MotoImg from "../../assets/Project/sanjeewa-web-developer-projects-portfolio-motogearlk-wordpress-website.avif";
import YogaImg from "../../assets/Project/sanjeewa-web-developer-projects-portfolio-sankalpayoga-yoga-institute-static-website.avif";
---

<section id="projects" class="projects">
  <div class="container">
    <div class="section-header">
      <h2 class="title">Selected Works</h2>
      <p class="subtitle">Engineering results for global businesses.</p>
    </div>

    <!-- Project 1 -->
    <article class="project">
      <div class="project-image">
        <img src={ElinaImg.src} alt="ElinaPix Photography Portfolio" loading="lazy">
      </div>
      <div class="project-content">
        <span class="project-category">seo focus</span>
        <h3 class="project-title">ElinaPix Portfolio</h3>
        <p class="project-desc">
          A high-fidelity visual experience for a French Riviera photographer. 
          Engineered to load 4K images instantly without compromising quality.
        </p>
        <ul class="project-stats">
          <li><strong>SEO:</strong> 100/100 Google Score</li>
          <li><strong>Tech:</strong> WordPress + Elementor</li>
        </ul>
        <a href="https://elinapix.com/" target="_blank" class="project-link">View Live Site &rarr;</a>
      </div>
    </article>

    <!-- Project 2 (Reversed) -->
    <article class="project project--reverse">
      <div class="project-image">
        <img src={MotoImg.src} alt="MotoGear E-Commerce" loading="lazy">
      </div>
      <div class="project-content">
        <span class="project-category">E-Commerce Architecture</span>
        <h3 class="project-title">MotoGear.lk</h3>
        <p class="project-desc">
          Scalable inventory management system handling 5,000+ SKUs. 
          Integrated dynamic shipping calculations and secure payment gateways.
        </p>
        <ul class="project-stats">
          <li><strong>Result:</strong> 20% Conversion Lift</li>
          <li><strong>Tech:</strong> WordPress + WooCommerce</li>
        </ul>
        <a href="https://motogear.lk/" target="_blank" class="project-link">View Live Site &rarr;</a>
      </div>
    </article>

    <!-- Project 3 -->
    <article class="project">
      <div class="project-image">
        <img src={YogaImg.src} alt="Sankalpa Yoga" loading="lazy">
      </div>
      <div class="project-content">
        <span class="project-category">Static Application</span>
        <h3 class="project-title">Sankalpa Yoga</h3>
        <p class="project-desc">
          A pure static architecture using Cloudflare Pages. 
          Zero database calls mean zero security vulnerabilities and instant global loading.
        </p>
        <ul class="project-stats">
          <li><strong>Load Time:</strong> 185 ms</li>
          <li><strong>Tech:</strong> HTML5(Astro) / Static</li>
        </ul>
        <a href="https://sankalpa-yoga.pages.dev/" target="_blank" class="project-link">View Live Site &rarr;</a>
      </div>
    </article>

  </div>
</section>