---
<section id="contact" class="contact">
  <div class="container contact-grid">
    
    <div class="contact-info">
      <h2 class="contact-title">Initialize<br>Collaboration</h2>
      <p class="contact-desc">
        I only take on 2 new projects per month to ensure quality. 
        Secure your slot for the upcoming quarter.
      </p>
      
      <div class="contact-methods">
        <a href="mailto:hello.sanjeewa@outlook.com" target="_blank" class="method">
          <span class="label">Email</span>
          <span class="value">hello.sanjeewa@outlook.com</span>
        </a>
        <a href="https://wa.me/94776369256" target="_blank" class="method">
          <span class="label">WhatsApp</span>
          <span class="value">+94 77 636 9256</span>
        </a>
      </div>
    </div>

    <!-- Contact form - Made with web3 forms -->
    <div class="contact-form-wrapper">
      <form action="https://api.web3forms.com/submit" method="POST" class="form">
        <input type="hidden" name="access_key" value="e86a016a-5bc4-4c27-9f8e-89b00560b268">
        <input type="hidden" name="redirect" value="https://sanjeewa.dev/success">

        <div class="form-group">
          <label for="name">Name / Company</label>
          <input type="text" id="name" name="name" required placeholder="Enter your name">
        </div>

        <div class="form-group">
          <label for="email">Your Email</label>
          <input type="email" id="email" name="email" required placeholder="name@company.com">
        </div>

        <div class="form-group">
          <label for="message">Project Details</label>
          <textarea id="message" name="message" rows="5" required placeholder="Describe your technical requirements..."></textarea>
        </div>

        <button type="submit" class="btn-submit">Request Consultation</button>
      </form>
    </div>

  </div>
</section>